{
  "name": "geospatial-audio-js",
  "version": "0.1.0",
  "description": "A JavaScript library for integrating 3D spatial audio with web map libraries",
  "type": "module",
  "main": "dist/geospatial-audio-js.umd.cjs",
  "module": "dist/geospatial-audio-js.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/geospatial-audio-js.js",
      "require": "./dist/geospatial-audio-js.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "dev:demo": "vite --config demo/vite.config.ts",
    "build:demo": "vite build --config demo/vite.config.ts",
    "dev:demo-cesium": "vite --config demo-cesium/vite.config.ts",
    "build:demo-cesium": "vite build --config demo-cesium/vite.config.ts",
    "dev:demo-intro": "vite --config demo-intro/vite.config.ts",
    "build:demo-intro": "vite build --config demo-intro/vite.config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "maplibre-gl": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "jsdom": "^26.0.0",
    "maplibre-gl": "^5.13.0",
    "typescript": "^5.8.0",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.1.0"
  },
  "keywords": [
    "geospatial",
    "audio",
    "3d-audio",
    "spatial-audio",
    "web-audio",
    "maplibre"
  ],
  "license": "MIT"
}
